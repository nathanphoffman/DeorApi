
import "lib/leptos.deor"

macro_block component Counter
	macro_block component_view
		<div>
			<h1>Counter</h1>
			<p>Count: 0</p>
			<button on:click=on_click>Increment</button>
		</div>

fn void on_click(MouseEvent ev)
	let count = use_context(CountSignal)
	signal_set(count, signal_get(count) + 1)
