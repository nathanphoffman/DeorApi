
import "lib/leptos.deor"

rust
	use wasm_bindgen::prelude::*;

macro_block component Counter
	let count = RwSignal::new(0);
	macro_block component_view
		<div>
			<h1>Counter</h1>
			<p>Count: {count}</p>
			<button on:click=move |_| *count.write() += 1>Increment</button>
		</div>

macro_block component App
	macro_block component_view
		<Counter />

rust
	#[wasm_bindgen(start)]
	pub fn main() {
		leptos::mount::mount_to_body(App);
	}
